{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    // improve debugging experience
    "sourceMap": true,
    // allow importing like import logger from 'src/logger'
    "baseUrl": "./",
    "module": "preserve",
    "moduleResolution": "bundler"
  },
  "include": ["./**/*.ts", "./**/*.tsx"],
  "exclude": ["node_modules", "cdk.out", "output"]
}
