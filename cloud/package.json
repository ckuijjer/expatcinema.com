{
  "name": "expatcinema.com-cloud",
  "version": "1.0.1",
  "description": "",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "tsx": "IS_LOCAL=true node --inspect --no-warnings --import tsx",
    "type-check": "tsc --noEmit",
    "tail-cloudwatch-logs": "AWS_PROFILE=casper aws logs tail /aws/lambda/expatcinema-dev --follow --region eu-west-1",
    "prettify-log": "awk -F'\\t' '{if ($5 && $5 ~ /^{/ && !system(\"echo \\x27\" $5 \"\\x27 | jq -e > /dev/null 2>&1\")) { print $1\"\\t\"$2\"\\t\"$3\"\\t\"$4 system(\"echo \\x27\" $5 \"\\x27 | jq\") } else { print $0 }}'",
    "prettify-log:test": "cat tail-cloudwatch-logs.example.log | pnpm prettify-log",
    "log": "pnpm tail-cloudwatch-logs|pnpm prettify-log",
    "install-chromium": "pnpx @puppeteer/browsers install chromium@latest --path /Applications/Chromium | awk '{print $2}' | xargs -I {} echo 'export const LOCAL_CHROMIUM_EXECUTABLE_PATH = `{}`;' > browser-local-constants.ts",
    "open-chromium": "node -e 'const { LOCAL_CHROMIUM_EXECUTABLE_PATH } = require(\"./browser-local-constants.ts\");console.log(LOCAL_CHROMIUM_EXECUTABLE_PATH)'|sh",
    "build": "tsc",
    "test": "jest",
    "bootstrap": "cdk bootstrap",
    "deploy:ci": "cdk deploy --require-approval never",
    "deploy": "AWS_PROFILE=casper STAGE=dev cdk deploy --hotswap-fallback",
    "synth": "AWS_PROFILE=casper STAGE=dev cdk synth",
    "watch": "AWS_PROFILE=casper STAGE=dev cdk watch --hotswap-fallback",
    "config:scrapers": "AWS_PROFILE=casper aws lambda get-function-configuration --function-name expatcinema-dev-scrapers",
    "scrapers": "AWS_PROFILE=casper aws lambda invoke --function-name expatcinema-dev-scrapers output/expatcinema-dev-scrapers.json",
    "scrapers:prod": "AWS_PROFILE=casper aws lambda invoke --function-name expatcinema-prod-scrapers output/expatcinema-prod-scrapers.json",
    "playground": "AWS_PROFILE=casper aws lambda invoke --function-name expatcinema-dev-playground output/expatcinema-dev-playground.json"
  },
  "author": "Casper Kuijjer",
  "license": "ISC",
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@aws-lambda-powertools/logger": "^2.32.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1014.0",
    "@aws-sdk/client-dynamodb": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/lib-dynamodb": "^3.1014.0",
    "@middy/core": "^7.2.1",
    "@sparticuz/chromium": "^143.0.4",
    "aws-cdk-lib": "2.244.0",
    "camelcase-keys": "^10.0.2",
    "constructs": "^10.5.1",
    "got": "^14.6.6",
    "graphql": "^16.13.1",
    "html-entities": "^2.6.0",
    "leven": "^4.1.0",
    "luxon": "^3.7.2",
    "p-map": "7.0.4",
    "p-retry": "^7.1.1",
    "puppeteer-core": "24.35.0",
    "react": "^19.2.4",
    "x-ray": "^2.3.4",
    "x-ray-crawler": "^2.0.5"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "25.5.0",
    "@types/x-ray": "^2.3.6",
    "aws-cdk": "2.1112.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "puppeteer": "24.35.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "why-is-node-running": "^3.2.2"
  }
}
